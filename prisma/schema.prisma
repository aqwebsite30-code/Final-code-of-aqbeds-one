generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  price       Float
  salePrice   Float?
  category    String
  stock       Int              @default(0)
  sku         String?          @unique
  rating      Float            @default(0)
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  images      ProductImage[]
  variants    ProductVariant[]
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size          String?
  color         String?
  fabric        String?
  mattress      String?
  frame         String?
  headboard     String?
  storage       String?
  priceModifier Float   @default(0)
  stock         Int     @default(0)
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  alt       String?
  sortOrder Int     @default(0)
}

model Order {
  id              String   @id @default(uuid())
  customerName    String
  customerEmail   String
  customerPhone   String
  customerAddress String
  items           String   // JSON string of cart items
  instructions    String?
  status          String   @default("pending")
  total           Float
  createdAt       DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}
model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String   // Anonymous session ID
  content   String
  isUser    Boolean  @default(true) // true if from customer, false if from admin
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}
